Data_Raw/*
!Data_Raw/.gitkeep
!Data_Raw/README.md

# Processed data — regenerated by scripts
Data_Processed/*
!Data_Processed/.gitkeep

# R session artifacts
.Rhistory
.RData
.Ruserdata
.Rproj.user/

# macOS system files
.DS_Store

# Various editor / OS
*.swp
*~
Thumbs.db
